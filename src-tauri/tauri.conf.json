{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "PakePlus",
    "version": "../package.json",
    "identifier": "com.pakeplus.app",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "security": {
            "assetProtocol": {
                "enable": true,
                "scope": {
                    "allow": [
                        "$APPCONFIG/**",
                        "$APPLOCALDATA/**",
                        "$APPCACHE/**",
                        "$APPDATA/**",
                        "$APPLOG/**",
                        "$AUDIO/**",
                        "$CACHE/**",
                        "$CONFIG/**",
                        "$DATA/**",
                        "$LOCALDATA/**",
                        "$DESKTOP/**",
                        "$DOCUMENT/**",
                        "$DOWNLOAD/**",
                        "$EXE/**",
                        "$FONT/**",
                        "$HOME/**",
                        "$PICTURE/**",
                        "$PUBLIC/**",
                        "$RUNTIME/**",
                        "$ASSETS/**",
                        "$VIDEO/**",
                        "$TEMP/**",
                        "$RESOURCE/../**",
                        "$ASSETS/**",
                        "$TEMPLATE/**",
                        "**",
                        "asset://localhost/**"
                    ],
                    "scope": [
                        "$APPCONFIG/**",
                        "$APPLOCALDATA/**",
                        "$APPCACHE/**",
                        "$APPDATA/**",
                        "$APPLOG/**",
                        "$AUDIO/**",
                        "$CACHE/**",
                        "$CONFIG/**",
                        "$DATA/**",
                        "$LOCALDATA/**",
                        "$DESKTOP/**",
                        "$DOCUMENT/**",
                        "$DOWNLOAD/**",
                        "$EXE/**",
                        "$FONT/**",
                        "$HOME/**",
                        "$PICTURE/**",
                        "$PUBLIC/**",
                        "$RUNTIME/**",
                        "$ASSETS/**",
                        "$VIDEO/**",
                        "$TEMP/**",
                        "$RESOURCE/../**",
                        "$ASSETS/**",
                        "$TEMPLATE/**",
                        "**",
                        "asset://localhost/**"
                    ],
                    "enable": true
                }
            },
            "csp": "default-src 'self' asset: 'unsafe-inline' customprotocol://* http://localhost:* ws:localhost:* 'unsafe-eval' ipc: http://ipc.localhost; script-src 'self' https://www.googletagmanager.com 'unsafe-inline'; connect-src 'self' http://localhost:* ws:localhost:* ipc://localhost https://api.github.com https://www.google-analytics.com https://google-analytics.com https://pakeplus.com http://ipc.localhost customprotocol://* https://www.pakeplus.com; img-src 'self' https://avatars.githubusercontent.com https://www.googletagmanager.com asset: http://asset.localhost blob: data: http://asset.localhost; font-src 'self' asset: http://localhost data:;",
            "dangerousDisableAssetCspModification": true
        },
        "withGlobalTauri": true
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBNjhENjYxMjZBQjQ0RgpSV1JQdEdvU1pvMm1ESFZ4Nmp4dzdTYmdHNkNobnBPLzQ1WWozT1g5L1hwTGVZVE9XWUFYVlppYQo=",
            "endpoints": [
                "https://files.pakeplus.com/ppupdate.json",
                "https://gh-proxy.com/github.com/Sjj1024/PakePlus/releases/latest/download/ppupdate.json"
            ],
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
